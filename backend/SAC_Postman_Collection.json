                  "mode": "raw",
                  "raw": "{\n  \"solicitanteNombre\": \"María González\",\n  \"solicitanteCorreo\": \"maria.gonzalez@uniquindio.edu.co\",\n  \"solicitanteTelefono\": \"3001234567\",\n  \"solicitanteIdentificacion\": \"1094567890\",\n  \"asunto\": \"Solicitud de homologación de materias\",\n  \"descripcion\": \"Deseo homologar las materias Cálculo I y Álgebra Lineal que cursé en mi universidad anterior con nota superior a 4.0.\",\n  \"canalOrigen\": \"SAC\"\n}",
